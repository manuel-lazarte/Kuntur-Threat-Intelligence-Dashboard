{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kuntur.io/schemas/attack-event.json",
  "title": "AttackEvent",
  "description": "Schema para eventos de ataque cibernético en Kuntur Threat Intelligence",
  "type": "object",
  "required": [
    "id",
    "timestamp",
    "source_ip",
    "attack_type",
    "severity",
    "confidence",
    "source_feed"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "UUID único del evento de ataque"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp ISO 8601 cuando ocurrió el ataque"
    },
    "source_ip": {
      "type": "string",
      "format": "ipv4",
      "description": "IP origen del ataque (atacante)"
    },
    "dest_ip": {
      "type": "string",
      "format": "ipv4",
      "description": "IP destino del ataque (víctima)"
    },
    "source_country": {
      "type": "string",
      "pattern": "^[A-Z]{2}$",
      "description": "Código ISO 3166-1 alpha-2 del país origen (ej: BO, US, BR)"
    },
    "dest_country": {
      "type": "string",
      "pattern": "^[A-Z]{2}$",
      "description": "Código ISO 3166-1 alpha-2 del país destino"
    },
    "source_lat": {
      "type": "number",
      "minimum": -90,
      "maximum": 90,
      "description": "Latitud de la IP origen (para renderizado en globo)"
    },
    "source_lng": {
      "type": "number",
      "minimum": -180,
      "maximum": 180,
      "description": "Longitud de la IP origen"
    },
    "dest_lat": {
      "type": "number",
      "minimum": -90,
      "maximum": 90,
      "description": "Latitud de la IP destino"
    },
    "dest_lng": {
      "type": "number",
      "minimum": -180,
      "maximum": 180,
      "description": "Longitud de la IP destino"
    },
    "attack_type": {
      "type": "string",
      "enum": [
        "port_scan",
        "brute_force",
        "malware_c2",
        "ddos",
        "exploit_attempt",
        "recon",
        "exfiltration",
        "other"
      ],
      "description": "Tipo de ataque según taxonomía de Kuntur"
    },
    "mitre_technique_id": {
      "type": "string",
      "pattern": "^T[0-9]{4}(\\.[0-9]{3})?$",
      "description": "ID de técnica MITRE ATT&CK (ej: T1110, T1110.001)"
    },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"],
      "description": "Nivel de severidad del ataque"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Nivel de confianza de la fuente (0 = no confiable, 1 = muy confiable)"
    },
    "source_feed": {
      "type": "string",
      "enum": ["demo", "tpot", "abuseipdb", "greynoise", "otx", "shodan", "cisa-kev", "cloudflare-radar"],
      "description": "Fuente de donde proviene el evento"
    },
    "involves_bolivia": {
      "type": "boolean",
      "description": "Indica si el evento involucra a Bolivia (como origen o destino). Calculado automáticamente en el pipeline."
    },
    "source_name": {
      "type": "string",
      "description": "Nombre legible de la fuente (añadido en el pipeline)"
    },
    "raw_data": {
      "type": "object",
      "description": "Datos crudos de la fuente original (opcional, para debug)"
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
      "timestamp": "2026-07-03T21:00:00.000Z",
      "source_ip": "186.2.8.0",
      "dest_ip": "8.8.8.8",
      "source_country": "BO",
      "dest_country": "US",
      "source_lat": -16.5,
      "source_lng": -68.15,
      "dest_lat": 37.4,
      "dest_lng": -122.1,
      "attack_type": "brute_force",
      "mitre_technique_id": "T1110",
      "severity": "high",
      "confidence": 0.85,
      "source_feed": "abuseipdb",
      "involves_bolivia": true
    }
  ]
}
