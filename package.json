{
  "name": "kuntur",
  "version": "2.0.0",
  "description": "Local threat intelligence engine - OSINT sources, live dashboard, auto-refresh, optional LLM layer.",
  "type": "module",
  "scripts": {
    "start": "node server.mjs",
    "dev": "node --trace-warnings server.mjs",
    "sweep": "node apis/briefing.mjs",
    "inject": "node dashboard/inject.mjs",
    "brief": "node apis/briefing.mjs",
    "brief:save": "node apis/save-briefing.mjs",
    "diag": "node diag.mjs",
    "clean": "node scripts/clean.mjs",
    "fresh-start": "npm run clean && npm start",
    "kuntur": "node apis/briefing.mjs",
    "kuntur:threat": "node apis/briefing.mjs threat",
    "kuntur:context": "node apis/briefing.mjs context",
    "kuntur:demo": "node apis/sources/demo-replay.mjs",
    "kuntur:cisa": "node apis/sources/cisa-kev.mjs",
    "kuntur:abuseipdb": "node apis/sources/abuseipdb.mjs",
    "kuntur:greynoise": "node apis/sources/greynoise.mjs",
    "kuntur:otx": "node apis/sources/otx.mjs",
    "kuntur:shodan": "node apis/sources/shodan.mjs",
    "kuntur:tpot": "node apis/sources/tpot.mjs"
