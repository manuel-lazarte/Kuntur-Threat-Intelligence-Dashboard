  },
  "dependencies": {
    "express": "^5.1.0",
    "ajv": "^8.17.1",
    "@maxmind/geoip2-node": "^5.0.0"
  },
  "optionalDependencies": {
    "discord.js": "^14.25.1"  },
  "overrides": {
    "undici": "^7.24.4"  }
